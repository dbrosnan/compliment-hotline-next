rus shadow-inner md:h-36 md:w-24 md:text-7xl\"><span class=\"relative z-10\">4</span><div class=\"absolute inset-x-0 top-1/2 border-t border-border/15\"></div></div><div class=\"relative flex h-24 w-16 items-center justify-center rounded-lg border border-border/30 bg-background/80 font-display text-5xl text-citrus shadow-inner md:h-36 md:w-24 md:text-7xl\"><span class=\"relative z-10\">7</span><div class=\"absolute inset-x-0 top-1/2 border-t border-border/15\"></div></div></div><p class=\"mt-6 text-muted-foreground/80\">and counting.</p></div></section><section id=\"submit\" class=\"relative px-6 py-24 md:py-32\"><div class=\"mx-auto w-full max-w-3xl\"><div class=\"text-center mb-10\"><p class=\"font-mono mb-4 text-xs uppercase tracking-[0.3em] text-muted-foreground\">Your turn</p><h2 class=\"font-display text-5xl md:text-7xl leading-none text-foreground\">LEAVE ONE</h2><p class=\"mt-4 font-serif italic text-lg md:text-xl text-muted-foreground leading-relaxed\" style=\"display:block;width:100%;max-width:36rem;margin-left:auto;margin-right:auto\">Kind. Specific. 30 seconds or 500 characters. Gets queued, reviewed, then plays on a real phone at the next festival.</p></div><div data-slot=\"card\" data-size=\"default\" class=\"group/card flex flex-col gap-4 overflow-hidden rounded-none py-4 text-xs/relaxed text-card-foreground ring-1 ring-foreground/10 has-data-[slot=card-footer]:pb-0 has-[&gt;img:first-child]:pt-0 data-[size=sm]:gap-2 data-[size=sm]:py-3 data-[size=sm]:has-data-[slot=card-footer]:pb-0 *:[img:first-child]:rounded-none *:[img:last-child]:rounded-none w-full bg-card/70 border-border/25 backdrop-blur-sm shadow-md\" style=\"width:100%\"><div data-slot=\"card-content\" class=\"group-data-[size=sm]/card:px-3 w-full p-6 md:p-10\" style=\"width:100%\"><div dir=\"ltr\" data-orientation=\"horizontal\" data-slot=\"tabs\" class=\"group/tabs flex gap-2 data-horizontal:flex-col w-full\" style=\"display:block;width:100%\"><div role=\"tablist\" aria-orientation=\"horiz